#!/usr/bin/env python3

import argparse
import socket
import ssl
import re
from html.parser import HTMLParser
from urllib.parse import urljoin, urlparse
from collections import deque

DEFAULT_SERVER = "fakebook.khoury.northeastern.edu"
DEFAULT_PORT = 443

# Extracting all href values from <a> tags
class LinkParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.links = []
    
    def handle_starttag(self, tag, attrs):
        if tag == "a":
            for name, val in attrs:
                if name == "href":
                    self.links.append(val)    
    
# Extracting the secret flags from <h3 class='secret_flag'> tags
class FlagParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.flags = []
        self._in_flag = False
    
    def handle_starttag(self, tag, attrs):
        if tag == "h3":
            attrs_dict = dict(attrs)
            if attrs_dict.get("class") == "secret_flag":
                self._in_flag = True
    
    def handle_endtag(self, tag):
        if tag == "h3" and self._in_flag:
            self._in_flag = False
    
    def handle_data(self, data):
        if self._in_flag:
            match = re.search(r'FLAG:\s*([A-Za-z0-9]{64})', data)
            if match:
                self.flags.append(match.group(1))
            self._in_flag = False

# Extract csrfmiddlewaretoken from the login page
class CSRFParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.csrf_token = None
    
    def handle_starttag(self, tag, attrs):
        if tag == "input":
            attrs_dict = dict(attrs)
            if attrs_dict.get("name") == "csrfmiddlewaretoken":
                self.csrf_token = attrs_dict.get("value")
                
